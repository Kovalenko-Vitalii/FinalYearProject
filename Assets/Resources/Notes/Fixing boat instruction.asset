  m_Script: {fileID: 11500000, guid: c7013fd6e1e162445b96703e5d818786, type: 3}
  m_Name: Fixing boat instruction
  m_EditorClassIdentifier: Assembly-CSharp::NoteData
  id: ae3817ac-4dc7-49e1-be42-42e0cb99661d
  noteName: How to fix boats
  icon: {fileID: 0}
  background: {fileID: 0}
  textContent: 'Whoever''s reading this, know that this boat is your only chance
    to escape this hell! The soldiers damaged it, but not critically. You need a
    navigation module and converter. Just install them where the sparks are, and
    you''re good to go! I''m done for, I''ve caught a bug, but you can still get
    out!

    The navigation module can definitely be salvaged from the military
    radar on the mountain. The converter belonged to Mikhalych, who lives in apartment
    #3.'
  onClickSound: {fileID: 0}
  onPickupSound: {fileID: 0}
